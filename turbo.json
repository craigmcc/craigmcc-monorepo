{
  "$schema": "https://v2-9-5.turborepo.dev/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "NODE_ENV",
    "VITEST"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "./dist/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "db-shopshop:deploy": {
      "cache": false
    },
    "db-shopshop:generate": {
      "cache": false
    },
    "db-shopshop:migrate": {
      "cache": false
    },
    "db-shopshop:migrate:test": {
      "cache": false
    },
    "db-shopshop:studio": {
      "cache": false
    },
    "db-shopshop:studio:test": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "cache": false,
      "persistent": true
    },
    "test:ci": {
      "dependsOn": [
        "^build"
      ]
    }
  },
  "ui": "tui"
}
